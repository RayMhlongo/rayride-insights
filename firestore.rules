rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        request.auth.token.email != null &&
        request.auth.token.email in ['admin@example.com'];
    }

    function isDriver(driverId) {
      return isSignedIn() && request.auth.uid == driverId;
    }

    function driverVerified(driverId) {
      return get(/databases/$(database)/documents/drivers/$(driverId)).data.verified == true;
    }

    function subscriptionActive(driverId) {
      return get(/databases/$(database)/documents/drivers/$(driverId)).data.subscriptionActive == true;
    }

    match /drivers/{driverId} {
      allow read: if isSignedIn();
      allow create: if isDriver(driverId);
      allow update: if isDriver(driverId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /rides/{rideId} {
      allow create: if true;
      allow read: if true;
      allow update: if isAdmin() ||
        (
          isSignedIn() &&
          request.resource.data.driverId == request.auth.uid &&
          driverVerified(request.auth.uid) &&
          subscriptionActive(request.auth.uid)
        ) ||
        (
          resource.data.status == 'completed' &&
          request.resource.data.driverId == resource.data.driverId &&
          request.resource.data.status == resource.data.status &&
          request.resource.data.rating is int &&
          request.resource.data.rating >= 1 &&
          request.resource.data.rating <= 5
        );
    }
  }
}
